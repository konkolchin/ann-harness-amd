diff --git a/CMakeLists.txt b/CMakeLists.txt
index b365242..62224c7 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -23,7 +23,10 @@ include(cmake/utils/compile_flags.cmake)
 include(cmake/utils/platform_check.cmake)
 
 knowhere_option(WITH_CUVS "Build with CUVS indexes" OFF)
-if(WITH_CUVS)
+knowhere_option(WITH_HIP "Link prebuilt hipVS/hipRAFT (ROCm) instead of CUDA cuVS" OFF)
+if(WITH_CUVS AND WITH_HIP)
+  include(cmake/libs/libhipcuvs.cmake)
+elseif(WITH_CUVS)
   set(CMAKE_CUDA_ARCHITECTURES RAPIDS)
   include(cmake/libs/librapids.cmake)
   project(knowhere CXX C CUDA)
@@ -204,10 +207,10 @@ if(WITH_CUVS)
     APPEND
     KNOWHERE_LINKER_LIBS
     raft::raft
-    cuvs::cuvs
-    CUDA::cublas
-    CUDA::cusparse
-    CUDA::cusolver)
+    cuvs::cuvs)
+  if(NOT WITH_HIP)
+    list(APPEND KNOWHERE_LINKER_LIBS CUDA::cublas CUDA::cusparse CUDA::cusolver)
+  endif()
 endif()
 target_link_libraries(knowhere PUBLIC ${KNOWHERE_LINKER_LIBS})
 target_include_directories(knowhere PUBLIC ${CMAKE_CURRENT_SOURCE_DIR}/include)
diff --git a/cmake/libs/libhipcuvs.cmake b/cmake/libs/libhipcuvs.cmake
new file mode 100644
index 0000000..7e429ce
--- /dev/null
+++ b/cmake/libs/libhipcuvs.cmake
@@ -0,0 +1,17 @@
+# Link prebuilt hipVS / hipRAFT (ROCm) instead of fetching cuVS via CPM + CUDAToolkit.
+
+add_definitions(-DKNOWHERE_WITH_CUVS)
+add_definitions(-DKNOWHERE_WITH_HIP)
+
+if(DEFINED ENV{INSTALL_PREFIX})
+  list(PREPEND CMAKE_PREFIX_PATH "$ENV{INSTALL_PREFIX}")
+endif()
+if(DEFINED ENV{HIPVS_PREFIX})
+  list(PREPEND CMAKE_PREFIX_PATH "$ENV{HIPVS_PREFIX}")
+endif()
+
+find_package(raft CONFIG REQUIRED)
+find_package(cuvs CONFIG REQUIRED)
+
+message(STATUS "KNOWHERE WITH_HIP: raft from ${raft_DIR}")
+message(STATUS "KNOWHERE WITH_HIP: cuvs from ${cuvs_DIR}")
