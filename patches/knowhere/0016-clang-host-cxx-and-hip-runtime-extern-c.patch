 /**
  * CUDA runtime shims for knowhere cuVS host code on ROCm.
- * Use hip_runtime_api.h only (not hip_runtime.h) so g++ never pulls
- * device-only fp16/bf16 headers.
+ * No HIP headers here — avoids pulling device bf16/fp16 into every TU.
+ * Symbols resolve via libamdhip64 (pulled in through raft/cuvs).
  */
 #pragma once
 
 #ifdef KNOWHERE_WITH_HIP
-#include <hip/hip_runtime_api.h>
+#include <cstddef>
 
+using hipError_t = int;
+using cudaError_t = hipError_t;
+constexpr hipError_t hipSuccess = 0;
 #define cudaSuccess hipSuccess
-#define cudaErrorUnknown hipErrorUnknown
-typedef hipError_t cudaError_t;
+
+extern "C" {
+hipError_t hipGetDeviceCount(int* count);
+const char* hipGetErrorString(hipError_t error);
+hipError_t hipMemGetInfo(std::size_t* free, std::size_t* total);
+hipError_t hipSetDevice(int deviceId);
+hipError_t hipGetDevice(int* deviceId);
+hipError_t hipDeviceSynchronize(void);
+hipError_t hipMalloc(void** ptr, std::size_t size);
+hipError_t hipFree(void* ptr);
+hipError_t hipMemcpy(void* dst, const void* src, std::size_t sizeBytes, int kind);
+hipError_t hipMemcpyAsync(void* dst, const void* src, std::size_t sizeBytes, int kind, void* stream);
+}
+
 #define cudaGetDeviceCount hipGetDeviceCount
 #define cudaGetErrorString hipGetErrorString
 #define cudaSetDevice hipSetDevice
