 set -euo pipefail
 _real_cxx=\"${_knowhere_real_cxx}\"
 args=()
@@ -101,6 +105,8 @@ for arg in \"\$@\"; do
 done
 exec \"\${_real_cxx}\" \"\${args[@]}\"
 ")
