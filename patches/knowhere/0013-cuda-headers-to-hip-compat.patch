diff --git a/src/common/cuvs/integration/cuda_compat.hpp b/src/common/cuvs/integration/cuda_compat.hpp
new file mode 100644
index 0000000..1111111
--- /dev/null
+++ b/src/common/cuvs/integration/cuda_compat.hpp
+/**
+ * CUDA runtime / fp16 headers for knowhere cuVS integration.
+ * On ROCm (KNOWHERE_WITH_HIP) map to HIP equivalents used by prebuilt hipRAFT/hipVS.
+ */
+#pragma once
+
+#ifdef KNOWHERE_WITH_HIP
+#include <hip/hip_runtime.h>
+
+#ifndef cudaSuccess
+#define cudaSuccess hipSuccess
+#endif
+#ifndef cudaError_t
+typedef hipError_t cudaError_t;
+#endif
+#ifndef cudaGetDeviceCount
+#define cudaGetDeviceCount hipGetDeviceCount
+#endif
+#ifndef cudaGetErrorString
+#define cudaGetErrorString hipGetErrorString
+#endif
+#ifndef cudaSetDevice
+#define cudaSetDevice hipSetDevice
+#endif
+#ifndef cudaGetDevice
+#define cudaGetDevice hipGetDevice
+#endif
+#ifndef cudaDeviceSynchronize
+#define cudaDeviceSynchronize hipDeviceSynchronize
+#endif
+#ifndef cudaMalloc
+#define cudaMalloc hipMalloc
+#endif
+#ifndef cudaFree
+#define cudaFree hipFree
+#endif
+#ifndef cudaMemcpy
+#define cudaMemcpy hipMemcpy
+#endif
+#ifndef cudaMemcpyAsync
+#define cudaMemcpyAsync hipMemcpyAsync
+#endif
+#ifndef cudaMemGetInfo
+#define cudaMemGetInfo hipMemGetInfo
+#endif
+
+#include <hip/hip_fp16.h>
+#ifndef half
+typedef __half half;
+#endif
+
+#else
+#include <cuda_runtime_api.h>
+#include <cuda_fp16.h>
+#endif

diff --git a/src/common/cuvs/integration/knowhere_gpu_device_count.hpp b/src/common/cuvs/integration/knowhere_gpu_device_count.hpp
new file mode 100644
index 0000000..1111111
--- /dev/null
+++ b/src/common/cuvs/integration/knowhere_gpu_device_count.hpp
+#pragma once
+
+#ifdef KNOWHERE_WITH_HIP
+#include "common/cuvs/integration/cuda_compat.hpp"
+#define KNOWHERE_GPU_GET_DEVICE_COUNT(count) \
+    do {                                     \
+        if (cudaGetDeviceCount(count) != cudaSuccess) { \
+            *(count) = 0;                    \
+        }                                    \
+    } while (0)
+#else
+#include <raft/util/cuda_rt_essentials.hpp>
+#define KNOWHERE_GPU_GET_DEVICE_COUNT(count) RAFT_CUDA_TRY(cudaGetDeviceCount(count))
+#endif

