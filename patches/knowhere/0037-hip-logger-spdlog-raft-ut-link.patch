   set(_knowhere_logger_cpp "")
   foreach(_prefix IN LISTS _knowhere_prefixes)
@@ -65,19 +74,19 @@ function(knowhere_hip_link_rmm _target)
   if(_knowhere_logger_cpp)
     target_sources(${_target} PRIVATE "${_knowhere_logger_cpp}")
     message(STATUS "KNOWHERE WITH_HIP: ${_target} compiles rmm logger from ${_knowhere_logger_cpp}")
-    if(TARGET spdlog::spdlog)
+    find_library(_knowhere_libspdlog NAMES spdlog PATHS ${_knowhere_prefixes}
+                 PATH_SUFFIXES lib NO_DEFAULT_PATH)
+    if(_knowhere_libspdlog)
+      target_link_libraries(${_target} PUBLIC "-Wl,--push-state" "-Wl,--no-as-needed"
+                            "${_knowhere_libspdlog}" "-Wl,--pop-state")
+      message(STATUS "KNOWHERE WITH_HIP: ${_target} linked ${_knowhere_libspdlog}")
+    elseif(TARGET spdlog::spdlog)
       target_link_libraries(${_target} PUBLIC spdlog::spdlog)
-    else()
-      find_library(_knowhere_libspdlog NAMES spdlog PATHS ${_knowhere_prefixes}
-                   PATH_SUFFIXES lib NO_DEFAULT_PATH)
-      if(_knowhere_libspdlog)
-        target_link_libraries(${_target} PUBLIC "${_knowhere_libspdlog}")
-        message(STATUS "KNOWHERE WITH_HIP: ${_target} linked ${_knowhere_libspdlog}")
-      elseif(TARGET spdlog::spdlog_header_only)
-        target_link_libraries(${_target} PUBLIC spdlog::spdlog_header_only)
-      endif()
-      unset(_knowhere_libspdlog)
+    elseif(TARGET spdlog::spdlog_header_only)
+      message(WARNING
+        "KNOWHERE WITH_HIP: spdlog header-only cannot satisfy compiled logger.cpp for ${_target}")
     endif()
+    unset(_knowhere_libspdlog)
   else()
     message(WARNING
       "KNOWHERE WITH_HIP: rmm logger impl not found; libknowhere may have undefined rmm::logger symbols")
@@ -87,8 +96,46 @@ function(knowhere_hip_link_rmm _target)
   unset(_knowhere_prefixes)
   unset(_knowhere_librmm)
   unset(_knowhere_librapids_logger)
+  unset(_knowhere_libraft)
   unset(_knowhere_logger_cpp)
   unset(_prefix)
   unset(_candidate)
   unset(_rmm_dep)
 endfunction()
+
+function(knowhere_hip_link_ut_logger_deps _target)
+  if(NOT WITH_HIP OR NOT WITH_CUVS)
+    return()
+  endif()
+
+  set(_knowhere_prefixes ${CMAKE_PREFIX_PATH})
+  if(DEFINED ENV{INSTALL_PREFIX})
+    set(_knowhere_install_prefix "$ENV{INSTALL_PREFIX}")
+    if(_knowhere_install_prefix MATCHES "^~")
+      if(DEFINED ENV{HOME})
+        string(REPLACE "~" "$ENV{HOME}" _knowhere_install_prefix "${_knowhere_install_prefix}")
+      endif()
+    endif()
+    get_filename_component(_knowhere_install_prefix "${_knowhere_install_prefix}" ABSOLUTE)
+    list(PREPEND _knowhere_prefixes "${_knowhere_install_prefix}")
+    unset(_knowhere_install_prefix)
+  endif()
+  list(REMOVE_DUPLICATES _knowhere_prefixes)
+
+  foreach(_lib IN ITEMS spdlog raft rapids_logger rmm)
+    set(_knowhere_lib "")
+    foreach(_prefix IN LISTS _knowhere_prefixes)
+      if(NOT _knowhere_lib)
+        find_library(_knowhere_lib NAMES "${_lib}" PATHS "${_prefix}/lib" NO_DEFAULT_PATH)
+      endif()
+    endforeach()
+    if(_knowhere_lib)
+      target_link_libraries(${_target} PRIVATE "-Wl,--push-state" "-Wl,--no-as-needed"
+                            "${_knowhere_lib}" "-Wl,--pop-state")
+      message(STATUS "KNOWHERE WITH_HIP: ${_target} linked ${_knowhere_lib}")
+    endif()
+    unset(_knowhere_lib)
+  endforeach()
+
+  unset(_knowhere_prefixes)
+endfunction()
