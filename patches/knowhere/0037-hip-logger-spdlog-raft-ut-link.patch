@@ -35,6 +36,9 @@ function(knowhere_hip_link_rmm _target)
       find_library(_knowhere_librapids_logger NAMES rapids_logger PATHS "${_prefix}/lib"
                    NO_DEFAULT_PATH)
     endif()
+    if(NOT _knowhere_libraft)
